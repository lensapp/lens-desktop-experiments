{
  "name": "lens-desktop-experiments",
  "private": true,
  "version": "0.1.0",
  "description": "Dynamic feature experiments for Lens Desktop",
  "workspaces": [
    "experiments/*"
  ],
  "scripts": {
    "build": "tsx infrastructure/build/build.ts",
    "build:experiment": "tsx infrastructure/build/build.ts --experiment",
    "typecheck": "tsx infrastructure/build/typecheck.ts",
    "test": "jest --passWithNoTests --forceExit",
    "sign": "tsx infrastructure/sign/sign-bundle.ts",
    "manifest": "tsx infrastructure/publish/generate-manifest.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "esbuild": "^0.24.0",
    "fast-glob": "^3.3.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}